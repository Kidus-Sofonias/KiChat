PORT=3001
NODE_ENV=development
JWT_SECRET=replace_me

# Render / PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/kichat
DB_SSL=false

# Frontend origin for production CORS
FRONTEND_URL=https://your-frontend.onrender.com

# Optional: comma-separated additional origins
ALLOWED_ORIGINS=

# Optional: explicit public backend URL for file links
BACKEND_PUBLIC_URL=
